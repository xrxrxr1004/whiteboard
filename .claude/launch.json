{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "whiteboard-python",
      "runtimeExecutable": "/usr/bin/python3",
      "runtimeArgs": ["-m", "http.server", "8000"],
      "port": 8000
    },
    {
      "name": "whiteboard-npx",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["http-server", "-p", "8080", "-c-1"],
      "port": 8080
    }
  ]
}
